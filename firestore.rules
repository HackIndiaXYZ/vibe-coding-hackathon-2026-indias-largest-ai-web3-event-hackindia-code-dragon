rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own user doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Sessions: only owner can read/write
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null && resource.data.owner == request.auth.uid;
      
      // Messages under session: inherit parent session permission
      match /messages/{messageId} {
        allow read, write: if request.auth != null && 
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.owner == request.auth.uid;
      }
    }

    // Public or open docs (if needed later)
    match /public/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
